#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_install:
	install -D -m 644 contrib/yazses.service \
		debian/yazses/usr/lib/systemd/user/yazses.service
	install -D -m 644 examples/config.example.toml \
		debian/yazses/usr/share/yazses/config.example.toml
